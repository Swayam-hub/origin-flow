// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  AGENCY_OWNER
  AGENCY_ADMIN
  SUBACCOUNT_USER
  SUBACCOUNT_ADMIN
}

model User {
  id            String         @id @default(uuid())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @default(now()) @updatedAt
  email         String         @unique
  password      String         @default("")
  name          String
  image         String?
  trial         Boolean        @default(false)
  role          Role           @default(SUBACCOUNT_USER)
  agencyId      String?
  Agency        Agency?        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  Notifications Notification[]
  Permissions   Permissions[]
  Tickets       Ticket[]

  @@index([agencyId])
}

model Agency {
  id                 String                @id @default(uuid())
  connectedAccountId String?               @default("")
  customerId         String                @default("")
  name               String                @default("")
  agencyLogo         String                @db.Text
  companyEmail       String                @db.Text
  companyPhone       String                @default("")
  whiteLabel         Boolean               @default(true)
  address            String                @default("")
  city               String                @default("")
  state              String                @default("")
  zipCode            String                @default("")
  country            String                @default("")
  goal               Int                   @default(5)
  users              User[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @default(now()) @updatedAt
  SubAccount         SubAccount[]
  Invitation         Invitation[]
  Notifications      Notification[]
  SidebarOptions     AgencySidebarOption[]
}

model SubAccount {
  id                 String                    @id @default(uuid())
  connectedAccountId String?                   @default("")
  name               String                    @default("")
  subAccountLogo     String                    @db.Text
  companyEmail       String                    @db.Text
  companyPhone       String                    @default("")
  whiteLabel         Boolean                   @default(true)
  address            String                    @default("")
  city               String                    @default("")
  state              String                    @default("")
  zipCode            String                    @default("")
  country            String                    @default("")
  goal               Int                       @default(5)
  agencyId           String
  Agency             Agency                    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  Notifications      Notification[]
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @default(now()) @updatedAt
  SidebarOptions     SubAccountSidebarOption[]
  Permissions        Permissions[]
  Pipeline           Pipeline[]
  Contact            Contact[]
  Tags               Tag[]

  @@index([agencyId])
}

enum InvitationStatus {
  REVOKED
  PENDING
  ACCEPTED
}

model Invitation {
  id       String           @id @default(uuid())
  email    String           @unique
  agencyId String
  Agency   Agency           @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  status   InvitationStatus @default(PENDING)
  role     Role             @default(SUBACCOUNT_USER)

  @@index([agencyId])
}

model Notification {
  id           String      @id @default(uuid())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @default(now()) @updatedAt
  User         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  Agency       Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  SubAccount   SubAccount? @relation(fields: [subAccountId], references: [id], onDelete: Cascade)
  notification String
  userId       String
  agencyId     String
  subAccountId String?

  @@index([agencyId])
  @@index([subAccountId])
  @@index([userId])
}

model AgencySidebarOption {
  id        String   @id @default(uuid())
  name      String   @default("Menu")
  icon      String   @default("info")
  link      String   @default("#")
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  Agency    Agency?  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  agencyId  String

  @@index([agencyId])
}

model SubAccountSidebarOption {
  id           String      @id @default(uuid())
  name         String      @default("Menu")
  icon         String      @default("info")
  link         String      @default("#")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @default(now()) @updatedAt
  SubAccount   SubAccount? @relation(fields: [subAccountId], references: [id], onDelete: Cascade)
  subAccountId String

  @@index([subAccountId])
}

model Permissions {
  id           String      @id @default(uuid())
  email        String
  userId       String
  subAccountId String
  SubAccount   SubAccount? @relation(fields: [subAccountId], references: [id], onDelete: Cascade)
  access       Boolean
  User         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([subAccountId])
  @@index([email])
}

model Pipeline {
  id           String      @id @default(uuid())
  name         String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @default(now()) @updatedAt
  Lane         Lane[]
  subAccountId String
  SubAccount   SubAccount? @relation(fields: [subAccountId], references: [id], onDelete: Cascade)

  @@index([subAccountId])
}

model Lane {
  id         String   @id @default(uuid())
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  Pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  pipelineId String
  Tickets    Ticket[]
  order      Int      @default(0)

  @@index([pipelineId])
}

model Ticket {
  id             String   @id @default(uuid())
  name           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
  laneId         String
  Lane           Lane     @relation(fields: [laneId], references: [id], onDelete: Cascade)
  order          Int      @default(0)
  value          Decimal?
  description    String?
  Tags           Tag[]
  customerId     String?
  customer       Contact? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  assignedUserId String?
  Assigned       User?    @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)

  @@index([laneId])
}

model Contact {
  id    String @id @default(uuid())
  name  String
  email String

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @default(now()) @updatedAt
  Ticket       Ticket[]
  subAccountId String
  SubAccount   SubAccount? @relation(fields: [subAccountId], references: [id], onDelete: Cascade)

  @@index([subAccountId])
}

model Tag {
  id           String      @id @default(uuid())
  name         String
  color        String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @default(now()) @updatedAt
  subAccountId String
  SubAccount   SubAccount? @relation(fields: [subAccountId], references: [id], onDelete: Cascade)
  Ticket       Ticket[]

  @@index([subAccountId])
}
